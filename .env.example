# NextAuth Configuration
NEXTAUTH_SECRET=your-secret-key-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# Turso Database (for production/Vercel deployment)
# Get these from https://turso.tech (free tier available)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# For local development, leave TURSO vars empty — it will use local file:portfolio.db
